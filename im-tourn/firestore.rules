rules_version = '2';

// ============================================================================
// I'm Tourn — Firestore Security Rules
// ============================================================================
//
// CHANGES IN THIS REVISION (custom brackets):
//   1. FIX: the `customBrackets` block was previously placed at the `service`
//      level, OUTSIDE `match /databases/{database}/documents`. Firestore can
//      only match paths under the documents root, so those rules were not
//      taking effect. It now lives inside the documents match alongside every
//      other collection.
//   2. Results/scores are frozen until the bracket is LOCKED. While a bracket
//      is `published` (predictions open) the host may ONLY flip the status —
//      no result writes leak in early.
//   3. Lifecycle now includes `complete -> locked` (reopen for corrections).
//   4. Non-draft custom brackets are publicly readable (parity with the public
//      `brackets` collection, so logged-out browse works).
//   5. Prediction `entries` are authored: public read for the leaderboard;
//      create only by the owner, while the parent is `published`, marked
//      submitted; no updates or deletes (a submitted prediction is locked in).
//
// Everything above the custom-brackets section is unchanged from your file.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    // Existing: Brackets collection
    // ========================================================================
    match /brackets/{bracketId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ========================================================================
    // Existing: Submissions collection
    // ========================================================================
    match /submissions/{submissionId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      // Upvote toggling uses updateDoc with increment() and array operations,
      // so update has to be allowed for any authenticated user.
      allow update: if request.auth != null
  && request.resource.data.diff(resource.data).affectedKeys()
    .hasOnly(['upvotes', 'upvotedBy']);
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ========================================================================
    // Existing: Weekly bracket collections (admin-managed)
    // ========================================================================
    match /weeklyBracket/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /weeklyVotes/{voteId} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /weeklyArchive/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ========================================================================
    // Existing: Bracket Pools
    // ========================================================================
    match /bracketPools/{poolId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.hostId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.hostId == request.auth.uid;
    }

    match /poolEntries/{entryId} {
  allow read: if true;

  // Users create their own entries.
  allow create: if request.auth != null
    && request.resource.data.userId == request.auth.uid;

  // Entry update is allowed if EITHER:
  //   (a) the writer owns the entry (e.g., submitting picks), OR
  //   (b) the writer is the host of the pool this entry belongs to
  //       (e.g., recalculating scores after setting results)
  allow update: if request.auth != null && (
    resource.data.userId == request.auth.uid
    ||
    get(/databases/$(database)/documents/bracketPools/$(resource.data.poolId)).data.hostId == request.auth.uid
  );

  // Same logic for delete — hosts need to delete entries when they
  // delete the pool, and users can delete their own entries.
  allow delete: if request.auth != null && (
    resource.data.userId == request.auth.uid
    ||
    get(/databases/$(database)/documents/bracketPools/$(resource.data.poolId)).data.hostId == request.auth.uid
  );
}

    // ========================================================================
    // Existing: Prediction Pools
    // ========================================================================
    match /predictionPools/{poolId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.hostId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.hostId == request.auth.uid;
    }

    match /predictionEntries/{entryId} {
      allow read: if true;

  // Users create their own entries.
  allow create: if request.auth != null
    && request.resource.data.userId == request.auth.uid;

  // Entry update is allowed if EITHER:
  //   (a) the writer owns the entry (e.g., submitting picks), OR
  //   (b) the writer is the host of the pool this entry belongs to
  //       (e.g., recalculating scores after setting results)
  allow update: if request.auth != null && (
    resource.data.userId == request.auth.uid
    ||
    get(/databases/$(database)/documents/predictionPools/$(resource.data.poolId)).data.hostId == request.auth.uid
  );

  // Same logic for delete — hosts need to delete entries when they
  // delete the pool, and users can delete their own entries.
  allow delete: if request.auth != null && (
    resource.data.userId == request.auth.uid
    ||
    get(/databases/$(database)/documents/predictionPools/$(resource.data.poolId)).data.hostId == request.auth.uid
  );
    }

    // ========================================================================
    // Existing: Public Rankings — head-to-head ranking feature
    // ========================================================================

    // Ranking metadata. Public readable; only the host can modify, EXCEPT
    // that voters need to be able to bump voteCount and refresh
    // consensusRanking when they submit a vote. We allow that narrowly.
    match /rankings/{rankingId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.hostId == request.auth.uid;

      // Host can update anything; non-hosts can only bump voteCount and
      // refresh consensusRanking/updatedAt (which happens during the vote
      // submission flow in submitRankingVote → recomputeRankingConsensus).
      allow update: if request.auth != null && (
        resource.data.hostId == request.auth.uid
        ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['voteCount', 'consensusRanking', 'updatedAt'])
      );

      allow delete: if request.auth != null
        && resource.data.hostId == request.auth.uid;
    }

    // Ranking entries (one doc per entry, with text + optional base64 image).
    // Only the ranking's host can create/update/delete these.
    match /rankingEntries/{entryId} {
      allow read: if true;

      // Creating an entry requires verifying the parent ranking is owned by
      // the caller.
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/rankings/$(request.resource.data.rankingId)).data.hostId == request.auth.uid;

      // Updating/deleting entries is host-only (same check).
      allow update, delete: if request.auth != null
        && get(/databases/$(database)/documents/rankings/$(resource.data.rankingId)).data.hostId == request.auth.uid;
    }

    // Votes — each voter's personal ranking. Doc ID is `${rankingId}_${userId}`,
    // which naturally enforces one-vote-per-user-per-ranking.
    match /rankingVotes/{voteId} {
      allow read: if true;

      // A voter can create their own vote. We validate that:
      //   1. The userId in the payload matches the authenticated user.
      //   2. The ranking is currently 'open' (not 'closed').
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && get(/databases/$(database)/documents/rankings/$(request.resource.data.rankingId)).data.status == 'open';

      // Re-voting — a user can update their own vote (if the ranking is
      // still open). This supports the "Vote Again" button.
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && get(/databases/$(database)/documents/rankings/$(resource.data.rankingId)).data.status == 'open';

      // Users can delete their own votes; hosts can delete any vote in
      // their ranking (used by deleteRanking cleanup).
      allow delete: if request.auth != null && (
        resource.data.userId == request.auth.uid
        ||
        get(/databases/$(database)/documents/rankings/$(resource.data.rankingId)).data.hostId == request.auth.uid
      );
    }

    // ========================================================================
    // Existing: Drafts — live snake-draft feature
    // ========================================================================
    match /drafts/{draftId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.hostId == request.auth.uid;

      // Updates are allowed for:
      //   (a) the host (start draft, delete, edit description, save scores)
      //   (b) any authenticated user for join/leave operations and picks
      //       (the service layer validates turn order and status; rules
      //       provide the base auth check)
      //
      // In an ideal world we'd have more granular field-level checks here,
      // but the single-document-for-everything architecture means many
      // different operations write to the same doc. The service layer is
      // the primary enforcement point for turn order, status transitions,
      // and authorization. The rules layer ensures authentication.
      allow update: if request.auth != null;

      allow delete: if request.auth != null
        && resource.data.hostId == request.auth.uid;
    }

    // ========================================================================
    // Custom Brackets — free-form positional brackets (decoupled from pools)
    // ========================================================================
    //
    // A custom bracket is just a structure, like a default bracket: draft ->
    // published. The owner manages it; anyone may read a published one (parity
    // with the public `brackets` collection); drafts are private to the host.
    // Filling one out for fun writes to a `submissions` subcollection. The
    // competition layer (predictions, scoring, leaderboards, host-entered
    // results) lives on a POOL that wraps the bracket — not here.
    match /customBrackets/{bracketId} {

      function isHost() { return request.auth != null && request.auth.uid == resource.data.hostId; }
      function isCreatingHost() { return request.auth != null && request.auth.uid == request.resource.data.hostId; }

      allow read: if isHost() || resource.data.status != 'draft';
      allow create: if isCreatingHost() && request.resource.data.status == 'draft';
      allow update: if isHost() && request.resource.data.hostId == resource.data.hostId;
      allow delete: if isHost();

      // Fill-out submissions — anyone signed in can save a filled bracket for fun.
      match /submissions/{submissionId} {
        allow read: if true;
        allow create: if request.auth != null
                      && request.resource.data.userId == request.auth.uid;
        allow update: if false;
        allow delete: if request.auth != null
                      && resource.data.userId == request.auth.uid;
      }
    }
  }
}
